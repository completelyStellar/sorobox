# HTTP server port
PORT=8080

# Runtime environment (local / dev / staging / production)
APP_ENV=local

DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=sorobox
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# Postgres connection string used at runtime (by cmd/api/main.go)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sorobox?sslmode=disable"

# Goose migration settings (used by goose CLI, not by the app)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING="postgresql://postgres:postgres@localhost:5432/sorobox"
GOOSE_MIGRATION_DIR=./migrations
